{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"outDir": "dist",
		"rootDir": ".",
		"jsx": "preserve",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"noEmit": true,
		"incremental": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"include": ["src", ".next/types/**/*.ts"],
	"references": [
		{
			"path": "../shared"
		}
	],
	"exclude": ["node_modules"]
}
