# Apogee local development environment
# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_USER=apogee
POSTGRES_PASSWORD=apogee_dev
POSTGRES_DB=apogee_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://apogee:apogee_dev@localhost:5432/apogee_dev
# Root/superuser connection used by graphile-migrate watch to create shadow databases
# Must point to a connection with CREATE DATABASE privileges
ROOT_DATABASE_URL=postgresql://apogee:apogee_dev@localhost:5432/postgres

# Redis (optional per ADR-008 — services fall back to PostgreSQL if absent)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Node / Bun
NODE_ENV=development
