{
	"name": "apogee",
	"version": "0.0.1",
	"private": true,
	"workspaces": ["packages/*"],
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/server/tsconfig.json --noEmit && tsc -p packages/web/tsconfig.json --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"build": "bun run --filter '*' build",
		"migrate": "cd packages/server && bun run migrate",
		"seed": "cd packages/server && bun run seed",
		"demo": "bun run scripts/demo.ts",
		"test:e2e": "bunx playwright test",
		"test:e2e:headed": "E2E_HEADED=1 bunx playwright test"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.0",
		"@playwright/test": "^1.59.1",
		"typescript": "^5.0.0"
	}
}
