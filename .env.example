# SatERP local development environment
# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_USER=saterp
POSTGRES_PASSWORD=saterp_dev
POSTGRES_DB=saterp_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://saterp:saterp_dev@localhost:5432/saterp_dev

# Redis (optional per ADR-008 — services fall back to PostgreSQL if absent)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Node / Bun
NODE_ENV=development
