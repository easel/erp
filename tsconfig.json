{
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"paths": {
			"@apogee/shared": ["./packages/shared/src"],
			"@apogee/server": ["./packages/server/src"],
			"@apogee/web": ["./packages/web/src"]
		}
	},
	"include": [],
	"references": [
		{ "path": "./packages/shared" },
		{ "path": "./packages/server" },
		{ "path": "./packages/web" }
	]
}
