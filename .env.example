# Apogee local development environment
# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL
POSTGRES_USER=apogee
POSTGRES_PASSWORD=apogee_dev
POSTGRES_DB=apogee_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://apogee:apogee_dev@localhost:5432/apogee_dev
# Root/superuser connection used by graphile-migrate watch to create shadow databases
# Must point to a connection with CREATE DATABASE privileges
ROOT_DATABASE_URL=postgresql://apogee:apogee_dev@localhost:5432/postgres

# Redis (optional per ADR-008 — services fall back to PostgreSQL if absent)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Keycloak (OIDC identity provider for local dev)
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev

# OIDC / Auth
# Issuer URL for the Apogee realm (set after first Keycloak start)
OIDC_ISSUER_URL=http://localhost:8080/realms/apogee
# Client ID registered in the apogee realm
OIDC_CLIENT_ID=apogee-api
# JWT secret (HS256) used by the Fastify auth middleware.
# For Keycloak RS256 tokens, replace with the realm's public key.
APP_JWT_SECRET=change-me-in-production-min-32-chars!

# Node / Bun
NODE_ENV=development
